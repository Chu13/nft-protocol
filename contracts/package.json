{
  "name": "obra-contracts",
  "version": "1.0.0",
  "description": "Obra ERC-721 collection + ObraMarket marketplace — Level 03 of a 3-project DeFi portfolio ecosystem, paid in CHU (Level 02's token)",
  "private": true,
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "seed:local": "hardhat run scripts/seed-local.ts --network localhost",
    "deploy": "hardhat run scripts/deploy.ts",
    "export-abi": "hardhat run scripts/export-abi.ts",
    "merkle": "ts-node scripts/merkle.ts",
    "generate-art": "ts-node art/generate.ts",
    "pin": "ts-node art/pin.ts",
    "clean": "hardhat clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.11",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.16.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.19",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.14",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/merkle-tree": "^1.0.7"
  }

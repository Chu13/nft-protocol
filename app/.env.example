# OBRA frontend — environment configuration
#
# Copy this file to `.env.local` (or `.env`) and fill in values as needed.
# All variables are prefixed NEXT_PUBLIC_ because they're read client-side —
# do not put secrets in this file.

# Which chain set is active. This is the ONLY switch needed to move the
# whole app between environments — no per-component chain literals exist
# anywhere else in the codebase (see lib/config/networks.ts).
#
#   local   -> Hardhat/localhost only (chainId 31337)
#   testnet -> BNB Chain Testnet (this project's current deploy target;
#              Ethereum Sepolia is structural but not deployed yet)
#   mainnet -> Ethereum mainnet + BNB Chain mainnet
#
# Defaults to "local" if unset.
NEXT_PUBLIC_NETWORK_ENV=local

# Optional custom RPC URLs. wagmi/viem fall back to each chain's public
# default RPC if these are unset.
NEXT_PUBLIC_BNB_TESTNET_RPC_URL=
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_BNB_MAINNET_RPC_URL=

# WalletConnect Cloud project ID, used by RainbowKit's getDefaultConfig for
# the WalletConnect (QR code) connector. Get one at https://cloud.walletconnect.com.
# Safe to leave blank for local development — injected wallets (MetaMask and
# other EIP-1193 browser extensions) work without it; only the WalletConnect
# QR-code connection path is degraded without a real project ID.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional dedicated Pinata gateway (e.g. https://your-gateway.mypinata.cloud)
# for resolving ipfs:// metadata/images faster than the public gateway.
# Falls back to https://gateway.pinata.cloud when unset — see lib/ipfs.ts.
NEXT_PUBLIC_IPFS_GATEWAY=

# Site URL used for social-share image resolution (metadataBase). Set to the
# Vercel deployment URL once known (Phase 6).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
